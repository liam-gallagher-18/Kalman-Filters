% Simple Kalman Filter (for 1D Spacecraft Position & Velocity)
clear; clc; close all;

% Setup
dt = 0.1;               % Time step (s)
t = 0:dt:10;            % Time vector
n = length(t);

% State Vector: [Position; Velocity]
A = [1 dt; 0 1];        % State Transition Matrix
C = [1 0];              % Measurement Matrix (only measuring position)
Q = [0.04 0; 0 0.04];   % Process Noise Covariance
R = 0.7;                % Measurement Noise Covariance

% Initialize
x_true = zeros(2, n);   % True state
z = zeros(1, n);        % Measurements
x_hat = zeros(2, n);    % Estimated state
P = eye(2);             % Initial Error Covariance

% Initial conditions
x_true(:,1) = [0; 10];  % Starting at 0m, moving at 10m/s
x_hat(:,1) = x_true(:,1);  % Initial guess based on theoretically correct state

% Kalman Filter Loop
for k = 2:n
    % True State
    w = mvnrnd([0;0], Q)'; 
    x_true(:,k) = A * x_true(:,k-1) + w;
    
    % Measurement (with noise)
    v = normrnd(0, sqrt(R));
    z(k) = C * x_true(:,k) + v;

    % Kalman Filter
    % Prediction:
    x_pred = A * x_hat(:,k-1);
    P_pred = A * P * A' + Q;
    % Update:
    K = P_pred * C' / (C * P_pred * C' + R); % Kalman Gain
    x_hat(:,k) = x_pred + K * (z(k) - C * x_pred);
    P = (eye(2) - K * C) * P_pred;
end

% Plots
figure;
subplot(2,1,1);
plot(t, x_true(1,:), 'g', t, z, 'r.', t, x_hat(1,:), 'b--');
title('Spacecraft Position Tracking');
legend('True Position', 'Noisy Measurements', 'Kalman Estimate', 'Location', 'Northwest');
ylabel('Position (m)');

subplot(2,1,2);
plot(t, x_true(2,:), 'g', t, x_hat(2,:), 'b--');
title('Spacecraft Velocity Estimation');
legend('True Velocity', 'Kalman Estimate');
ylabel('Velocity (m/s)');
xlabel('Time (s)');
